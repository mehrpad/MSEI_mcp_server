# ─────────────────────────────────────────────────────────────────────────
# MSEI publication-RAG configuration.
#
#   1. Copy this file to ".env":   cp .env.example .env
#   2. Fill in GEMINI_API_KEY.
#   3. Leave the rest as-is unless you know you need to change it.
#
# The .env file holds a secret (your API key) — never commit it to git.
# ─────────────────────────────────────────────────────────────────────────

# ── REQUIRED: Google Gemini embedding API key ────────────────────────────
# Used by the server to turn search queries into vectors. One key for the
# whole server (NOT one per user). Get it at https://aistudio.google.com/apikey
# Full walkthrough: docs/05-google-api-key.md
GEMINI_API_KEY=PASTE-YOUR-KEY-HERE

# ── Which vector database to serve ───────────────────────────────────────
# The "prefix" of the four Qdrant collections this server answers from.
# Default production corpus = materials_v2. To serve a different corpus,
# restore its snapshots and change this value, then restart (docs/08).
COLLECTION_PREFIX=materials_v2

# ── Embedding model ──────────────────────────────────────────────────────
# MUST be the same model the data was ingested with (in the separate ingest
# repo), otherwise search quality collapses. Don't change unless ingestion did.
EMBED_MODEL=gemini-embedding-2-preview

# ── Network ──────────────────────────────────────────────────────────────
# Port the MCP server is published on. OpenCode clients connect to
#   http://<VM-IP>:<HOST_PORT>/mcp
HOST_PORT=8080

# ── Optional: serve a SECOND corpus at the same time ─────────────────────
# Starts a second MCP server (compose profile "second") on its own port,
# serving a different collection prefix. Enable with:
#   docker compose --profile second up -d
# Then point those users at http://<VM-IP>:<HOST_PORT_2>/mcp  (docs/08).
# COLLECTION_PREFIX_2=materials_v2_external
# HOST_PORT_2=8081

# ── Optional: persistent audit log ───────────────────────────────────────
# By default, who-searched-what (IP + username) is written to the container
# logs (docker compose logs mcp). Uncomment to also keep a permanent file.
# AUDIT_LOG=/data/audit.log

# ── Optional: API-token authentication (DISABLED by default) ─────────────
# Leave empty = open (trust the network + the X-User header each user sets).
# To require a token per user, list "token=username" pairs, comma-separated.
# Each user then puts their token in OpenCode as an Authorization header
# (see docs/10-api-token-auth.md). Generate tokens with: openssl rand -hex 24
# MCP_AUTH_TOKENS=2f9a...e1=anna.k,7c3b...90=ben.r

# ── Optional: protect Qdrant with an API key ─────────────────────────────
# Only needed if you ever expose Qdrant beyond loopback. Leave empty otherwise.
# QDRANT_API_KEY=

# ── Optional: log verbosity (DEBUG, INFO, WARNING) ───────────────────────
# LOG_LEVEL=INFO
