# This project is developed on Windows but DEPLOYED ON LINUX. Shell scripts and
# the Dockerfile MUST use LF line endings or they break on the VM
# (`/usr/bin/env: bash\r: No such file or directory`). Force LF everywhere.

* text=auto eol=lf

*.sh        text eol=lf
*.py        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
Dockerfile  text eol=lf

# Binary artifacts — never normalize.
*.snapshot  binary
*.tar.gz    binary
